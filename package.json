{
  "name": "boostmyskills",
  "version": "0.1.0",
  "private": true,
  "description": "BoostMySkills micro-credential LMS (UAT build) — Next.js + TypeScript, SQL-first, Clerk, Backblaze B2, AWS Amplify Gen 2.",
  "type": "module",
  "engines": {
    "node": ">=20.11"
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "format:check": "prettier --check \"{app,components,lib,scripts,tests}/**/*.{ts,tsx,mjs,mts,css,md}\"",
    "format:write": "prettier --write \"{app,components,lib,scripts,tests}/**/*.{ts,tsx,mjs,mts,css,md}\"",
    "typecheck": "tsc --noEmit",
    "db:up": "docker compose up -d db",
    "db:down": "docker compose down",
    "db:migrate": "node --experimental-strip-types scripts/db/migrate.mts",
    "db:seed": "node --experimental-strip-types scripts/db/seed.mts",
    "db:seed:ui": "node --experimental-strip-types --import ./scripts/_register-hooks.mjs scripts/db/seed-ui.mts",
    "db:reset": "node --experimental-strip-types scripts/db/reset.mts",
    "test:unit": "vitest run --dir tests/unit",
    "test:db": "vitest run --dir tests/db --no-file-parallelism",
    "test": "vitest run --no-file-parallelism",
    "verify": "node --experimental-strip-types scripts/verify.mts",
    "db:backup": "node --experimental-strip-types scripts/db/backup.mts",
    "db:restore:verify": "node --experimental-strip-types scripts/db/restore-verify.mts",
    "test:e2e": "playwright test",
    "test:e2e:auth": "node --experimental-strip-types scripts/e2e/run-auth-e2e.mts",
    "security:audit": "node --experimental-strip-types scripts/security/audit.mts",
    "security:audit:raw": "npm audit --omit=dev --audit-level=high",
    "security:audit:local": "node --experimental-strip-types scripts/security/audit.mts"
  },
  "overrides": {
    "postcss": ">=8.5.10"
  },
  "dependencies": {
    "@clerk/nextjs": "^6.9.6",
    "fast-xml-parser": "^4.5.7",
    "next": "15.5.21",
    "pdf-lib": "^1.17.1",
    "pg": "^8.13.1",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.2.0",
    "@playwright/test": "^1.61.1",
    "@types/node": "^22.10.5",
    "@types/pg": "^8.11.10",
    "@types/react": "^19.0.2",
    "@types/react-dom": "^19.0.2",
    "eslint": "^9.17.0",
    "eslint-config-next": "15.5.21",
    "prettier": "^3.4.2",
    "standardwebhooks": "^1.0.0",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  }
}
