# =============================================================================
# BoostMySkills — environment variable reference (NAMES + SAFE DESCRIPTIONS ONLY)
# =============================================================================
# NEVER commit real secret values. Copy to `.env.local` for local development.
# UAT and Production values live only in AWS Secrets Manager / Amplify env config.
# UAT and Production MUST use isolated databases, buckets and Clerk instances.

# --- Environment identity ----------------------------------------------------
# One of: local | test | uat | production
APP_ENV=local
# Public base URL of this deployment (used for canonical URLs, sitemap, verification links)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# --- Database (PostgreSQL; UAT/Prod via RDS Proxy) ---------------------------
# Full connection string. Local dev example uses the docker-compose db on port 5433.
DATABASE_URL=postgres://bms:bms_local_dev_only@localhost:5433/bms
# Whether to require TLS to the database. true in UAT/Production (RDS), false locally.
DATABASE_SSL=false
# Optional path to the RDS CA bundle when DATABASE_SSL=true and cert verification is enforced.
DATABASE_SSL_CA_PATH=

# --- Separate database URL used ONLY by the automated test suite -------------
# Point this at a throwaway database; the suite creates/drops schema objects here.
TEST_DATABASE_URL=postgres://bms:bms_local_dev_only@localhost:5433/bms_test

# --- Authentication: Clerk ---------------------------------------------------
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
# Secret used to verify Clerk webhook signatures (user.created/updated sync).
CLERK_WEBHOOK_SIGNING_SECRET=
# Clerk hosted route configuration.
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/dashboard
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/dashboard

# --- Test authentication adapter --------------------------------------------
# ONLY honoured when APP_ENV=test. Enables a header/cookie-driven identity so the
# integration/E2E suites can run without a live Clerk instance. MUST be false/unset
# in any non-test build. See lib/auth/testAuth.ts.
TEST_AUTH_ENABLED=false
# Shared secret required alongside the test-identity header (defence in depth).
TEST_AUTH_SECRET=

# --- File / object storage: Backblaze B2 (S3-compatible API) -----------------
# Use SEPARATE buckets (or clearly isolated prefixes + credentials) per environment.
B2_ENDPOINT=
B2_REGION=
B2_BUCKET=
B2_KEY_ID=
B2_APPLICATION_KEY=
# Prefix applied to every object key for this environment (e.g. "uat/").
B2_KEY_PREFIX=

# --- Observability (optional) ------------------------------------------------
LOG_LEVEL=info
SENTRY_DSN=
